{
  "color": {
    "$type": "color",
    "primary": {
      "50": { "$value": { "colorSpace": "srgb", "components": [0.93, 0.95, 1.0] } },
      "100": { "$value": { "colorSpace": "srgb", "components": [0.85, 0.9, 1.0] } },
      "500": { "$value": { "colorSpace": "srgb", "components": [0.2, 0.4, 0.9] }, "$description": "Primary brand" },
      "600": { "$value": { "colorSpace": "srgb", "components": [0.15, 0.3, 0.8] } },
      "700": { "$value": { "colorSpace": "srgb", "components": [0.1, 0.2, 0.7] } }
    },
    "neutral": {
      "50": { "$value": { "colorSpace": "srgb", "components": [0.98, 0.98, 0.98] } },
      "100": { "$value": { "colorSpace": "srgb", "components": [0.95, 0.95, 0.96] } },
      "200": { "$value": { "colorSpace": "srgb", "components": [0.9, 0.9, 0.91] } },
      "500": { "$value": { "colorSpace": "srgb", "components": [0.5, 0.5, 0.53] } },
      "700": { "$value": { "colorSpace": "srgb", "components": [0.25, 0.25, 0.28] } },
      "900": { "$value": { "colorSpace": "srgb", "components": [0.1, 0.1, 0.12] } }
    },
    "danger": {
      "500": { "$value": { "colorSpace": "srgb", "components": [0.9, 0.2, 0.2] } },
      "600": { "$value": { "colorSpace": "srgb", "components": [0.8, 0.15, 0.15] } }
    },
    "success": {
      "500": { "$value": { "colorSpace": "srgb", "components": [0.15, 0.7, 0.4] } }
    },
    "surface": {
      "default": { "$value": "{color.neutral.50}" },
      "card": { "$value": "{color.neutral.100}" },
      "input": { "$value": { "colorSpace": "srgb", "components": [1.0, 1.0, 1.0] } }
    },
    "text": {
      "default": { "$value": "{color.neutral.900}" },
      "muted": { "$value": "{color.neutral.500}" },
      "inverse": { "$value": "{color.neutral.50}" }
    },
    "border": {
      "default": { "$value": "{color.neutral.200}" },
      "focus": { "$value": "{color.primary.500}" }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": { "$value": { "value": 4, "unit": "px" } },
    "sm": { "$value": { "value": 8, "unit": "px" } },
    "md": { "$value": { "value": 12, "unit": "px" } },
    "lg": { "$value": { "value": 16, "unit": "px" } },
    "xl": { "$value": { "value": 24, "unit": "px" } },
    "2xl": { "$value": { "value": 32, "unit": "px" } },
    "3xl": { "$value": { "value": 48, "unit": "px" } }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": { "value": 4, "unit": "px" } },
    "md": { "$value": { "value": 8, "unit": "px" } },
    "lg": { "$value": { "value": 12, "unit": "px" } },
    "full": { "$value": { "value": 9999, "unit": "px" } }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "body": { "$value": ["Inter", "system-ui", "sans-serif"], "$description": "Body text" },
      "mono": { "$value": ["JetBrains Mono", "Menlo", "monospace"], "$description": "Code" }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": { "value": 0.75, "unit": "rem" } },
      "sm": { "$value": { "value": 0.875, "unit": "rem" } },
      "base": { "$value": { "value": 1, "unit": "rem" } },
      "lg": { "$value": { "value": 1.125, "unit": "rem" } },
      "xl": { "$value": { "value": 1.25, "unit": "rem" } },
      "2xl": { "$value": { "value": 1.5, "unit": "rem" } }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    }
  },
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": {
        "color": { "colorSpace": "srgb", "components": [0, 0, 0, 0.05] },
        "offsetX": { "value": 0, "unit": "px" },
        "offsetY": { "value": 1, "unit": "px" },
        "blur": { "value": 2, "unit": "px" },
        "spread": { "value": 0, "unit": "px" }
      }
    },
    "md": {
      "$value": {
        "color": { "colorSpace": "srgb", "components": [0, 0, 0, 0.1] },
        "offsetX": { "value": 0, "unit": "px" },
        "offsetY": { "value": 4, "unit": "px" },
        "blur": { "value": 6, "unit": "px" },
        "spread": { "value": -1, "unit": "px" }
      }
    }
  },
  "animation": {
    "$type": "duration",
    "fast": { "$value": { "value": 150, "unit": "ms" } },
    "normal": { "$value": { "value": 250, "unit": "ms" } }
  }
}
